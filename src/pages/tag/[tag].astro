---
import { localizePath } from "@/i18n/paths";
import Layout from "../../layouts/Layout.astro";
import { getPostList, getPostsByTag, type ShortPostData } from "@/lib/posts";

export async function getStaticPaths() {
  const allPosts = await getPostList(true, "zh");
  const tagsMap = new Map<string, ShortPostData[]>();
  allPosts.forEach((post) => {
    post.tags.forEach((tag) => {
      if (!tagsMap.has(tag)) {
        tagsMap.set(tag, []);
      }
      tagsMap.get(tag)?.push(post);
    });
  });

  return Array.from(tagsMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: { tag, posts },
  }));
}

const { tag, posts } = Astro.props;
const locale = "zh" as const;
const hasEnPosts = (await getPostsByTag(tag, "en")).length > 0;
const encodedTag = encodeURIComponent(tag);
---

<Layout
  locale={locale}
  languageSwitchPath={hasEnPosts ? `/en/tag/${encodedTag}` : "/en/tags"}
  title={`Tag: ${tag}`}
  description={`${tag} 相关文章列表`}
  seo={{
    robots: "noindex,follow",
    alternateLocales: hasEnPosts
      ? {
          zh: `/tag/${encodedTag}`,
          en: `/en/tag/${encodedTag}`,
        }
      : undefined,
  }}
>
  <div class="retro-shell flex flex-col gap-8">
    <section class="animate-slide-in border-b-2 border-text pb-6">
      <div class="page-kicker">Tag</div>
      <h1 class="page-title mt-2">#{tag}</h1>
      <p class="page-description mt-4">共 {posts?.length || 0} 篇相关文章</p>
    </section>

    <div class="flex flex-col gap-6">
      {
        posts?.map((item, index) => (
          <article
            class="group relative rounded-lg border-2 border-border bg-card p-4 transition-all duration-300 hover:border-text hover:shadow-[4px_4px_0_0_var(--color-text)] md:p-5"
            style={`animation-delay: ${index * 100}ms`}
          >
            <div class="flex flex-col justify-between gap-4 md:flex-row md:items-start">
              <div class="flex-1 min-w-0">
                <div class="meta-row mb-2">
                  <span class="flex items-center gap-1">
                    <div class="i-ri:calendar-line" />
                    {new Date(item.createTime).toLocaleDateString("zh-CN")}
                  </span>
                </div>

                <h2 class="mb-3 line-clamp-2 text-xl font-black text-text md:text-2xl">
                  <a
                    href={localizePath(`/post/${item.slug}`, locale)}
                    class="group-hover:underline decoration-2 underline-offset-4 transition-colors"
                  >
                    {item.title}
                  </a>
                </h2>

                <p class="mb-4 line-clamp-3 text-sm leading-relaxed text-text-muted md:text-base">
                  {item.intro || "暂无简介"}
                </p>

                <div class="flex flex-wrap gap-2 mt-auto">
                  {item.tags.map((t) => (
                    <a
                      href={localizePath(`/tag/${encodeURIComponent(t)}`, locale)}
                      class={t === tag ? "article-tag border-text bg-text text-bg" : "article-tag hover:border-text hover:text-text"}
                    >
                      #{t}
                    </a>
                  ))}
                </div>
              </div>

              {item.cover && (
                <div class="h-32 w-full flex-shrink-0 overflow-hidden rounded border-2 border-text md:h-24 md:w-32">
                  <a
                    href={localizePath(`/post/${item.slug}`, locale)}
                    class="block w-full h-full"
                  >
                    <img
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                      src={item.cover.src}
                      alt={item.cover.alt || item.title}
                      loading="lazy"
                    />
                  </a>
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</Layout>
