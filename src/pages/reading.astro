---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { BookCard } from "@/components/BookCard";

// 从 posts 集合中筛选带有 "reading" 标签的文章
const allPosts = await getCollection("posts");
const books = allPosts.filter(
  (post) => post.data.tags.includes("reading") && !post.data.draft,
);

// 按日期排序
const sortedBooks = books.sort((a, b) => {
  const dateA =
    a.data.finishDate || a.data.startDate || a.data.date || new Date(0);
  const dateB =
    b.data.finishDate || b.data.startDate || b.data.date || new Date(0);
  return dateB.getTime() - dateA.getTime();
});
---

<Layout
  title="阅读 - Aleks Blog"
  description="我的阅读记录和书单"
  className="max-w-[1200px]"
>
  <!-- Google Fonts: Caveat + Quicksand (Only for reading page) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
  <link
    href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Quicksand:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
    slot="head"
  />

  <div class="space-y-8">
    <section class="text-center py-8 md:py-12 animate-slide-in">
      <h1
        class="text-4xl md:text-5xl font-bold text-text mb-4 drop-shadow-[2px_2px_0_var(--color-shadow)]"
      >
        阅读
      </h1>
 
    </section>

    {
      books.length === 0 ? (
        <div class="text-center py-20">
          <div class="i-ri:book-line w-20 h-20 mx-auto text-text-muted mb-4" />
          <p class="text-text-muted text-lg">还没有添加任何书籍</p>
        </div>
      ) : (
        <div
          id="books-grid"
          class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"
        >
          {sortedBooks.map((book) => {
            const bookData = {
              title: book.data.title,
              author: book.data.author,
              cover: book.data.cover,
              status: book.data.status || "completed",
              rating: book.data.rating,
              startDate: book.data.startDate,
              finishDate: book.data.finishDate,
              notes: book.data.intro,
              pages: book.data.pages,
            };
            return <BookCard client:load book={bookData} slug={book.slug} />;
          })}
        </div>
      )
    }
  </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const bookItems = document.querySelectorAll("#books-grid > *");
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

        // Intersection Observer for scroll animations
        if (!prefersReducedMotion) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("animate-fade-in");
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.1 },
          );

          bookItems.forEach((item) => {
            if (item instanceof HTMLElement) {
              item.style.opacity = "0";
              observer.observe(item);
            }
          });
        }
      });
    </script>

  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.6s ease-out forwards;
    }
  </style>
</Layout>
