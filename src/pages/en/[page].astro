---
import { localizePath } from "@/i18n/paths";
import Home from "@/components/Home.astro";
import { getPostList } from "@/lib/posts";
import { sortByPin } from "@/shared/tag";

export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const rawPosts = await getPostList(true, "en");
  const zhPosts = await getPostList(true, "zh");
  const posts = sortByPin(rawPosts);
  const zhTotalPages = Math.max(1, Math.ceil(zhPosts.length / PAGE_SIZE));
  const totalPages = Math.ceil(posts.length / PAGE_SIZE);

  if (totalPages <= 1) {
    return [];
  }

  return Array.from({ length: totalPages - 1 }, (_, index) => {
    const page = index + 2;
    const start = (page - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;

    return {
      params: { page: String(page) },
      props: {
        page,
        posts: posts.slice(start, end),
        allPosts: posts,
        more: page < totalPages,
        languageSwitchPath:
          page <= zhTotalPages ? localizePath(`/${page}`, "zh") : "/",
        seoAlternates:
          page <= zhTotalPages
            ? {
                zh: localizePath(`/${page}`, "zh"),
                en: localizePath(`/${page}`, "en"),
              }
            : undefined,
      },
    };
  });
}

const { page, posts, allPosts, more, languageSwitchPath, seoAlternates } = Astro.props;
---

<Home
  locale="en"
  posts={posts}
  allPosts={allPosts}
  page={page}
  more={more}
  languageSwitchPath={languageSwitchPath}
  seoAlternates={seoAlternates}
/>
