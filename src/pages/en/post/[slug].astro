---
import MDXCode from "@/components/mdx/MDXCode.astro";
import MDXImage from "@/components/mdx/MDXImage.astro";
import MDXTable from "@/components/mdx/MDXTable.astro";
import { localizePath } from "@/i18n/paths";
import Layout from "@/layouts/Layout.astro";
import {
  buildPostSeoDescription,
  buildPostSeoKeywords,
  getCoverFromTags,
  getPostAlternateLocalePaths,
  getPostBySlug,
} from "@/lib/posts";
import { getCollection } from "astro:content";
import config from "site.config";

export async function getStaticPaths() {
  const posts = await getCollection(
    "posts",
    ({ data }) => !data.draft && (data.locale || "zh") === "en",
  );
  const sortedPosts = posts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );

  return sortedPosts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      prev: sortedPosts[index + 1]
        ? {
            slug: sortedPosts[index + 1].slug,
            title: sortedPosts[index + 1].data.title,
          }
        : null,
      next: sortedPosts[index - 1]
        ? {
            slug: sortedPosts[index - 1].slug,
            title: sortedPosts[index - 1].data.title,
          }
        : null,
    },
  }));
}

const { slug } = Astro.params;
const { prev, next } = Astro.props;
const locale = "en" as const;
const post = await getPostBySlug(slug!, locale);

if (!post) {
  return Astro.redirect("/404");
}

const { Content, headings } = await post.render();

const toc = headings
  .filter((h) => h.depth <= 3)
  .map((h) => ({
    text: h.text,
    id: h.slug,
    depth: h.depth,
  }));

const siteUrl = (Astro.site || config.siteUrl).toString().replace(/\/$/, "");
const alternates = await getPostAlternateLocalePaths(post);
const languageSwitchPath = alternates.zh || "/";
const postPath = localizePath(`/post/${post.slug}`, locale);
const postUrl = new URL(postPath, `${siteUrl}/`).toString();
const showSidebar = post?.showSidebar ?? true;
const coverData = post.data.cover
  ? { src: post.data.cover }
  : getCoverFromTags(post.data.tags);

const seoImagePath = post.data.seoImage || coverData.src;
const coverImage = seoImagePath.startsWith("http")
  ? seoImagePath
  : new URL(seoImagePath, `${siteUrl}/`).toString();

const seoTitle = post.data.seoTitle || post.data.title;
const seoDescription =
  post.data.seoDescription ||
  buildPostSeoDescription(post.data.title, post.data.intro, post.body);
const seoKeywords = post.data.seoKeywords?.length
  ? post.data.seoKeywords
  : buildPostSeoKeywords({
      title: post.data.title,
      tags: post.data.tags,
      intro: post.data.intro,
      body: post.body,
    });
const giscusConfig = config.giscus
  ? { ...config.giscus, "data-lang": "en" }
  : null;
---

<Layout
  locale={locale}
  languageSwitchPath={languageSwitchPath}
  title={seoTitle}
  description={seoDescription}
  className="max-w-[1200px]"
  seo={{
    type: "article",
    locale,
    alternateLocales: alternates,
    image: coverImage,
    publishedTime: post.data.date.toISOString(),
    modifiedTime: post.data.updatedAt
      ? post.data.updatedAt.toISOString()
      : undefined,
    author: config.head.title,
    tags: post.data.tags,
    keywords: seoKeywords,
    url: postUrl,
  }}
>
  <div
    class:list={[
      "grid grid-cols-1 gap-8 items-start",
      { "layout-grid-cols": showSidebar },
    ]}
  >
    <article
      class="w-full min-w-0 bg-card p-6 md:p-12 rounded-xl border-4 border-text shadow-[8px_8px_0_0_var(--color-text)] md:shadow-[12px_12px_0_0_var(--color-text)]"
    >
      <header class="mb-12 pb-12 border-b-4 border-text animate-fade-in-up">
        <div class="flex flex-wrap gap-3 mb-8">
          {
            post.data.tags.map((tag) => (
              <a
                href={localizePath(`/tag/${encodeURIComponent(tag)}`, locale)}
                class="px-3 py-1.5 text-sm font-black uppercase tracking-wider rounded-md border-2 border-text text-text bg-transparent shadow-[4px_4px_0_0_var(--color-text)] hover:translate-y-[2px] hover:translate-x-[2px] hover:shadow-none transition-all"
              >
                #{tag}
              </a>
            ))
          }
        </div>

        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-black mb-8 leading-none tracking-tight text-text"
        >
          {post.data.title}
        </h1>

        <div
          class="flex items-center gap-6 text-base font-bold text-text-muted uppercase tracking-wide"
        >
          <time
            datetime={post.data.date.toISOString()}
            class="flex items-center gap-2"
          >
            <div class="i-ri:calendar-line text-xl"></div>
            {post.data.date.toLocaleDateString("en-US")}
          </time>
          {
            post.data.updatedAt && (
              <span class="flex items-center gap-2" title="Last updated">
                <div class="i-ri:time-line text-xl" />
                {post.data.updatedAt.toLocaleDateString("en-US")}
              </span>
            )
          }
        </div>
      </header>

      <div
        class="prose prose-lg md:prose-xl dark:prose-invert max-w-none break-words prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-headings:font-black prose-headings:scroll-mt-24 animate-fade-in-up [animation-delay:150ms]"
      >
        <Content
          components={{ img: MDXImage, pre: MDXCode, table: MDXTable }}
        />
      </div>

      <nav
        class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-16 pt-12 border-t-4 border-text animate-fade-in-up [animation-delay:300ms]"
      >
        {
          prev ? (
            <a
              href={localizePath(`/post/${prev.slug}`, locale)}
              class="group flex flex-col gap-2 p-6 rounded-xl border-4 border-text shadow-[8px_8px_0_0_var(--color-text)] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all bg-card"
            >
              <span class="text-sm font-bold uppercase tracking-widest text-text-muted flex items-center gap-2 group-hover:text-primary">
                <div class="i-ri:arrow-left-double-line text-xl" />
                Previous post
              </span>
              <span class="text-xl font-black truncate text-text">
                {prev.title}
              </span>
            </a>
          ) : (
            <div />
          )
        }
        {
          next ? (
            <a
              href={localizePath(`/post/${next.slug}`, locale)}
              class="group flex flex-col gap-2 p-6 rounded-xl border-4 border-text shadow-[8px_8px_0_0_var(--color-text)] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all text-right bg-card"
            >
              <span class="text-sm font-bold uppercase tracking-widest text-text-muted flex items-center gap-2 justify-end group-hover:text-primary">
                Next post
                <div class="i-ri:arrow-right-double-line text-xl" />
              </span>
              <span class="text-xl font-black truncate text-text">
                {next.title}
              </span>
            </a>
          ) : (
            <div />
          )
        }
      </nav>

      {
        giscusConfig && (
          <div class="giscus-container mt-16 pt-12 border-t-4 border-text animate-fade-in-up [animation-delay:450ms]">
            <script {...giscusConfig} />
          </div>
        )
      }
    </article>

    {
      showSidebar && (
        <aside class="hidden lg:block sticky top-24 animate-fade-in-up [animation-delay:300ms]">
          {toc.length > 0 && (
            <div class="p-6 rounded-xl border-4 border-text bg-card shadow-[8px_8px_0_0_var(--color-text)] max-h-[calc(100vh-8rem)] overflow-y-auto custom-scrollbar">
              <div class="text-base font-black text-text mb-6 uppercase tracking-widest border-b-2 border-text pb-2">
                On this page
              </div>
              <nav class="flex flex-col gap-1 text-sm">
                {toc.map((heading) => {
                  if (!heading.id) return;
                  return (
                    <a
                      href={`#${heading.id}`}
                      class="toc-link block py-2 px-3 font-bold text-text-muted hover:text-text hover:bg-white/5 rounded-md transition-all duration-200 hover:translate-x-2 break-words text-sm leading-snug border-2 border-transparent"
                      data-id={heading.id}
                      style={`padding-left: calc(0.75rem + ${(heading.depth - 1) * 0.75}rem)`}
                    >
                      {heading.text}
                    </a>
                  );
                })}
              </nav>
            </div>
          )}
        </aside>
      )
    }
  </div>
</Layout>

<script type="module">
  if (document.querySelector(".mermaid")) {
    const { default: mermaid } =
      await import("https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs");

    const html = document.documentElement;
    const isDark =
      html.classList.contains("dark") ||
      (!html.classList.contains("light") &&
        window.matchMedia("(prefers-color-scheme: dark)").matches);

    mermaid.initialize({
      startOnLoad: true,
      theme: isDark ? "dark" : "default",
      themeVariables: isDark ? { darkMode: true } : { darkMode: false },
    });
  }
</script>

<script>
  let isManualScroll = false;
  let scrollTimeout: NodeJS.Timeout;

  const updateActiveLink = (id: string) => {
    document.querySelectorAll(".toc-link").forEach((link) => {
      const isActive = link.getAttribute("data-id") === id;
      link.classList.toggle("text-text", isActive);
      link.classList.toggle("text-text-muted", !isActive);
      link.classList.toggle("font-black", isActive);
      link.classList.toggle("font-bold", !isActive);
      link.classList.toggle("border-text", isActive);
      link.classList.toggle("border-transparent", !isActive);
      link.classList.toggle("shadow-[4px_4px_0_0_var(--color-text)]", isActive);
      link.classList.toggle("-translate-y-[2px]", isActive);
      link.classList.toggle("-translate-x-[2px]", isActive);
      link.classList.toggle("bg-card", isActive);
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      if (isManualScroll) return;

      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          updateActiveLink(id);
        }
      });
    },
    {
      rootMargin: "-100px 0px -60% 0px",
    },
  );

  document.querySelectorAll("h1[id], h2[id], h3[id]").forEach((h) => {
    observer.observe(h);
  });

  document.querySelectorAll(".toc-link").forEach((link) => {
    link.addEventListener("click", (e) => {
      isManualScroll = true;
      const id = (e.currentTarget as HTMLElement).getAttribute("data-id");
      if (id) updateActiveLink(id);

      if (scrollTimeout) clearTimeout(scrollTimeout);

      scrollTimeout = setTimeout(() => {
        isManualScroll = false;
      }, 800);
    });
  });
</script>

<style>
  @media (min-width: 1024px) {
    .layout-grid-cols {
      grid-template-columns: minmax(0, 1fr) 240px;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
