---
import { localizePath } from "@/i18n/paths";
import Layout from "@/layouts/Layout.astro";
import { getPostList, type ShortPostData } from "@/lib/posts";

const locale = "zh" as const;
const allPosts = await getPostList(true, locale);

// 按年份分组
const postsByYear = new Map<number, ShortPostData[]>();
allPosts.forEach((post) => {
  const year = new Date(post.createTime).getFullYear();
  if (!postsByYear.has(year)) {
    postsByYear.set(year, []);
  }
  postsByYear.get(year)!.push(post);
});

// 按年份倒序排列
const sortedYears = Array.from(postsByYear.keys()).sort((a, b) => b - a);
---

<Layout
  locale={locale}
  languageSwitchPath="/en/archives"
  title="归档"
  description="所有文章归档"
  seo={{
    robots: "noindex,follow",
    alternateLocales: {
      zh: "/archives",
      en: "/en/archives",
    },
  }}
>
  <div class="retro-shell flex flex-col gap-8">
    <section class="animate-slide-in border-b-2 border-text pb-6">
      <div class="page-kicker">Archives</div>
      <h1 class="page-title mt-2">归档</h1>
      <p class="page-description mt-4">共 {allPosts.length} 篇文章，按时间索引所有技术笔记。</p>
    </section>

    <div class="flex flex-col gap-12">
      {
        sortedYears.map((year, yearIndex) => {
          const yearPosts = postsByYear.get(year)!;
          return (
            <div
              class="flex flex-col gap-6"
              style={`animation-delay: ${yearIndex * 100}ms`}
            >
              <h2 class="flex items-end gap-3 border-b-2 border-text pb-2 text-2xl font-black text-text md:text-3xl">
                {year}
                <span class="pb-1 text-sm font-bold text-text-muted">
                  ({yearPosts.length} 篇)
                </span>
              </h2>

              <div class="flex flex-col gap-3">
                {yearPosts.map((post, index) => (
                  <article
                    class="group relative rounded-lg border-2 border-border bg-card p-4 transition-all duration-300 hover:border-text hover:shadow-[4px_4px_0_0_var(--color-text)] md:p-5"
                    style={`animation-delay: ${index * 50}ms`}
                  >
                    <div class="flex flex-col justify-between gap-4 md:flex-row md:items-start">
                      <div class="flex-1 min-w-0">
                        <div class="meta-row mb-2">
                          <span class="flex items-center gap-1">
                            <div class="i-ri:calendar-line" />
                            {new Date(post.createTime).toLocaleDateString("zh-CN", {
                              year: "numeric",
                              month: "long",
                              day: "numeric",
                            })}
                          </span>
                        </div>

                        <h3 class="mb-2 text-lg font-black text-text md:text-xl">
                          <a
                            href={localizePath(`/post/${post.slug}`, locale)}
                            class="group-hover:underline decoration-2 underline-offset-4 transition-colors hover:text-primary"
                          >
                            {post.title}
                          </a>
                        </h3>

                        {post.intro && (
                          <p class="mb-3 line-clamp-2 text-sm leading-relaxed text-text-muted md:text-base">
                            {post.intro}
                          </p>
                        )}

                        <div class="flex flex-wrap gap-2">
                          {post.tags.map((tag) => (
                            <a
                              href={localizePath(
                                `/tag/${encodeURIComponent(tag)}`,
                                locale
                              )}
                              class="article-tag hover:border-text hover:text-text"
                            >
                              #{tag}
                            </a>
                          ))}
                        </div>
                      </div>

                      {post.cover && (
                        <div class="h-24 w-full flex-shrink-0 overflow-hidden rounded border-2 border-text md:w-28">
                          <a
                            href={localizePath(`/post/${post.slug}`, locale)}
                            class="block w-full h-full"
                          >
                            <img
                              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                              src={post.cover.src}
                              alt={post.cover.alt || post.title}
                              loading="lazy"
                            />
                          </a>
                        </div>
                      )}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</Layout>
