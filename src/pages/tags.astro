---
import { localizePath } from "@/i18n/paths";
import Layout from "@/layouts/Layout.astro";
import { getPostList, getAllTags } from "@/lib/posts";

const locale = "zh" as const;
const allPosts = await getPostList(true, locale);
const allTags = await getAllTags(locale);

// 统计每个标签的文章数量
const tagCountMap = new Map<string, number>();
allPosts.forEach((post) => {
  post.tags.forEach((tag) => {
    tagCountMap.set(tag, (tagCountMap.get(tag) || 0) + 1);
  });
});

// 按文章数量排序
const sortedTags = allTags.sort((a, b) => {
  const countA = tagCountMap.get(a) || 0;
  const countB = tagCountMap.get(b) || 0;
  return countB - countA;
});
---

<Layout
  locale={locale}
  languageSwitchPath="/en/tags"
  title="标签"
  description="所有标签"
  seo={{
    robots: "noindex,follow",
    alternateLocales: {
      zh: "/tags",
      en: "/en/tags",
    },
  }}
>
  <div class="retro-shell flex flex-col gap-8">
    <section class="animate-slide-in border-b-2 border-text pb-6">
      <div class="page-kicker">Tags</div>
      <h1 class="page-title mt-2">标签</h1>
      <p class="page-description mt-4">共 {allTags.length} 个标签，按主题浏览文章。</p>
    </section>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        sortedTags.map((tag, index) => {
          const count = tagCountMap.get(tag) || 0;
          return (
            <a
              href={localizePath(`/tag/${encodeURIComponent(tag)}`, locale)}
              class="group relative flex items-center justify-between rounded-lg border-2 border-border bg-card p-4 transition-all duration-300 hover:border-text hover:shadow-[4px_4px_0_0_var(--color-text)]"
              style={`animation-delay: ${index * 50}ms`}
            >
              <span class="min-w-0 truncate text-lg font-black text-text group-hover:text-primary">
                #{tag}
              </span>
              <span class="ml-3 rounded border border-border bg-bg-secondary px-2 py-1 text-xs font-black text-text-muted">
                {count} 篇
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</Layout>
