---
import "@/styles/theme.css";
import "@/index.scss";
import Footer from "@/components/Footer.astro";
import SEO from "@/components/SEO.astro";
import PageLoader from "@/components/PageLoader.astro";
import { LOCALE_META, type Locale } from "@/i18n/config";
import {
  getLocaleFromPathname,
  localizePath,
  switchLocalePath,
} from "@/i18n/paths";
import { getUiText } from "@/i18n/ui";

interface Props {
  title?: string;
  description?: string;
  footer?: boolean;
  className?: string;
  locale?: Locale;
  languageSwitchPath?: string | null;
  seo?: {
    image?: string;
    type?: "website" | "article";
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
    keywords?: string[];
    robots?: string;
    url?: string;
    locale?: Locale;
    alternateLocales?: Partial<Record<Locale, string>>;
  };
}

const {
  title,
  description,
  footer = true,
  className = "max-w-[1200px]",
  locale,
  languageSwitchPath,
  seo = {},
} = Astro.props;

const resolvedLocale = locale || getLocaleFromPathname(Astro.url.pathname);
const ui = getUiText(resolvedLocale);
const nextLocale: Locale = resolvedLocale === "zh" ? "en" : "zh";
const resolvedLanguageSwitchPath =
  languageSwitchPath === undefined
    ? switchLocalePath(Astro.url.pathname, nextLocale)
    : languageSwitchPath;

const homePath = localizePath("/", resolvedLocale);
const archivesPath = localizePath("/archives", resolvedLocale);
const tagsPath = localizePath("/tags", resolvedLocale);
const aboutPath = localizePath("/about", resolvedLocale);
const rssPath = localizePath("/rss.xml", resolvedLocale);
const seoPayload = {
  ...seo,
  locale: seo.locale || resolvedLocale,
};
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || "vb1cwv7d1k";
const enableClarity = import.meta.env.PROD && Boolean(clarityId);
---

<!doctype html>
<html lang={LOCALE_META[resolvedLocale].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content="Blog" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="baidu-site-verification" content="codeva-tU6pIQVfyl" />
    <meta name="msvalidate.01" content="96ADAC3B4A010DE98F0350319BAF9DAB" />
    <meta
      name="blogarama-site-verification"
      content="blogarama-05af7d29-9b70-41be-aca4-a6f95ceb722f"
    />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed"
      href={rssPath}
    />
    <title>
      {title}
    </title>

    <SEO title={title} description={description} {...seoPayload} />

    <slot name="head" />

    {
      enableClarity && (
        <script is:inline define:vars={{ clarityId }}>
          const loadClarity = () => {
            (function (c, l, a, r, i, t, y) {
              c[a] =
                c[a] ||
                function () {
                  (c[a].q = c[a].q || []).push(arguments);
                };
              t = l.createElement(r);
              t.async = 1;
              t.src = "https://www.clarity.ms/tag/" + i;
              y = l.getElementsByTagName(r)[0];
              y.parentNode.insertBefore(t, y);
            })(window, document, "clarity", "script", clarityId);
          };

          if ("requestIdleCallback" in window) {
            window.requestIdleCallback(loadClarity, { timeout: 3000 });
          } else {
            window.setTimeout(loadClarity, 1500);
          }
        </script>
      )
    }

    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }

      window.localStorage.setItem("theme", theme);

      const viewMode = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("view-mode")
        ) {
          return localStorage.getItem("view-mode");
        }
        return "card";
      })();

      if (viewMode === "terminal") {
        document.documentElement.classList.add("terminal-mode");
      }
    </script>
  </head>
  <body
    class="bg-bg text-text min-h-screen flex flex-col font-sans transition-colors duration-300"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:rounded focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-bold focus:text-bg"
    >
      {ui.actions.skipToContent}
    </a>

    <PageLoader />
    <slot name="background" />
    <header
      id="main-header"
      class="sticky top-0 z-50 w-full border-b-2 border-text bg-bg/95 backdrop-blur transition-transform duration-300"
    >
      <div
        class="max-w-[1200px] mx-auto px-4 h-16 flex items-center justify-between"
      >
        <a
          href={homePath}
          class="group text-xl font-black flex items-center gap-2 hover:text-text transition-colors"
          aria-label={ui.actions.backHomeAria}
        >
          <span
            class="flex h-9 w-9 items-center justify-center rounded border-2 border-text bg-card shadow-[3px_3px_0_0_var(--color-accent)] transition-transform group-hover:translate-x-[1px] group-hover:translate-y-[1px]"
          >
            <div class="i-ri:home-4-line w-5 h-5"></div>
          </span>
          <span class="hidden sm:inline tracking-tight">AleksChen</span>
        </a>

        <div class="flex items-center gap-4">
          <nav
            id="main-nav"
            class="hidden md:flex items-center gap-5"
            aria-label={ui.nav.mainNavAria}
          >
            <a
              href={archivesPath}
              class="text-sm font-extrabold text-text-muted hover:text-text transition-colors"
            >
              {ui.nav.archives}
            </a>
            <a
              href={tagsPath}
              class="text-sm font-extrabold text-text-muted hover:text-text transition-colors"
            >
              {ui.nav.tags}
            </a>
            <a
              href={aboutPath}
              class="text-sm font-extrabold text-text-muted hover:text-text transition-colors"
            >
              {ui.nav.about}
            </a>
          </nav>

          <div class="flex items-center gap-3 pl-4 border-l-2 border-text">
            {
              resolvedLanguageSwitchPath && (
                <a
                  href={resolvedLanguageSwitchPath}
                  class="flex items-center justify-center hover:text-primary transition-transform hover:scale-110 focus:outline-none"
                  aria-label={ui.actions.switchLanguageAria}
                  title={ui.actions.switchLanguageAria}
                >
                  <div class="i-ri:translate-2 w-5 h-5" aria-hidden="true"></div>
                </a>
              )
            }

            <div class="flex items-center">
              <slot name="operations" />
            </div>

            <button
              id="theme-toggle"
              class="flex items-center justify-center hover:text-primary transition-transform hover:scale-110 focus:outline-none"
              aria-label={ui.actions.toggleTheme}
              aria-pressed="false"
            >
              <div class="i-ri:sun-line w-5 h-5 dark:hidden" aria-hidden="true">
              </div>
              <div
                class="i-ri:moon-line w-5 h-5 hidden dark:block"
                aria-hidden="true"
              >
              </div>
            </button>

            <button
              id="mobile-menu-toggle"
              class="md:hidden flex items-center justify-center hover:text-primary transition-transform hover:scale-110 focus:outline-none"
              aria-label={ui.actions.openMenu}
              aria-expanded="false"
              aria-controls="mobile-nav"
              data-open-label={ui.actions.openMenu}
              data-close-label={ui.actions.closeMenu}
            >
              <div
                id="menu-icon-open"
                class="i-ri:menu-line w-6 h-6"
                aria-hidden="true"
              >
              </div>
              <div
                id="menu-icon-close"
                class="i-ri:close-line w-6 h-6 hidden"
                aria-hidden="true"
              >
              </div>
            </button>
          </div>
        </div>
      </div>

      <div
        id="mobile-nav"
        class="hidden md:hidden border-t-2 border-text bg-bg/98 backdrop-blur"
        aria-label={ui.nav.mobileNavAria}
      >
        <nav class="max-w-[1200px] mx-auto px-4 py-4 flex flex-col gap-1">
          <a
            href={archivesPath}
            class="rounded px-3 py-3 text-sm font-extrabold hover:bg-bg-secondary hover:text-primary transition-colors"
            >{ui.nav.archives}</a
          >
          <a
            href={tagsPath}
            class="rounded px-3 py-3 text-sm font-extrabold hover:bg-bg-secondary hover:text-primary transition-colors"
            >{ui.nav.tags}</a
          >
          <a
            href={aboutPath}
            class="rounded px-3 py-3 text-sm font-extrabold hover:bg-bg-secondary hover:text-primary transition-colors"
            >{ui.nav.about}</a
          >
          {
            resolvedLanguageSwitchPath && (
              <a
                href={resolvedLanguageSwitchPath}
                class="rounded px-3 py-3 text-sm font-extrabold hover:bg-bg-secondary hover:text-primary transition-colors"
              >
                {ui.actions.switchLanguageAria}
              </a>
            )
          }
        </nav>
      </div>
    </header>

    <main
      id="main-content"
      class={`flex-1 w-full mx-auto px-4 py-8 md:py-10 animate-fade-in ${className}`}
      tabindex="-1"
    >
      <slot />
    </main>

    {footer && <Footer locale={resolvedLocale} />}

    <script>
      const themeBtn = document.getElementById("theme-toggle");

      const syncAriaPressed = () => {
        const isDark = document.documentElement.classList.contains("dark");
        themeBtn?.setAttribute("aria-pressed", String(isDark));
      };

      const handleToggleClick = () => {
        const element = document.documentElement;
        const isDark = element.classList.contains("dark");

        if (document.startViewTransition) {
          document.startViewTransition(() => {
            element.classList.toggle("dark");
            localStorage.setItem("theme", !isDark ? "dark" : "light");
            syncAriaPressed();
          });
        } else {
          element.classList.add("theme-transitioning");
          element.classList.toggle("dark");
          localStorage.setItem("theme", !isDark ? "dark" : "light");
          syncAriaPressed();
          setTimeout(() => {
            element.classList.remove("theme-transitioning");
          }, 300);
        }
      };

      themeBtn?.addEventListener("click", handleToggleClick);
      syncAriaPressed();
    </script>

    <script>
      const menuToggle = document.getElementById("mobile-menu-toggle");
      const mobileNav = document.getElementById("mobile-nav");
      const iconOpen = document.getElementById("menu-icon-open");
      const iconClose = document.getElementById("menu-icon-close");

      menuToggle?.addEventListener("click", () => {
        const isExpanded = menuToggle.getAttribute("aria-expanded") === "true";
        const openLabel = menuToggle.getAttribute("data-open-label") || "Open";
        const closeLabel =
          menuToggle.getAttribute("data-close-label") || "Close";

        menuToggle.setAttribute("aria-expanded", String(!isExpanded));
        menuToggle.setAttribute(
          "aria-label",
          isExpanded ? openLabel : closeLabel,
        );
        mobileNav?.classList.toggle("hidden");
        iconOpen?.classList.toggle("hidden");
        iconClose?.classList.toggle("hidden");
      });
    </script>

    <script>
      let lastScrollY = window.scrollY;
      const header = document.getElementById("main-header");

      const updateHeader = () => {
        const currentScrollY = window.scrollY;

        if (!header) return;

        if (currentScrollY < lastScrollY || currentScrollY <= 100) {
          header.classList.remove("-translate-y-full");
        } else if (currentScrollY > 100 && currentScrollY > lastScrollY) {
          header.classList.add("-translate-y-full");
        }

        lastScrollY = currentScrollY;
      };

      window.addEventListener("scroll", updateHeader, { passive: true });
    </script>

    <script
      define:vars={{
        awayTitle: ui.visibility.away,
        backTitle: ui.visibility.back,
      }}
    >
      let originalTitle = document.title;
      let timeoutId;

      document.addEventListener("visibilitychange", () => {
        const icon = document.querySelector("link[rel*='icon']");

        if (document.hidden) {
          if (document.title !== awayTitle && document.title !== backTitle) {
            originalTitle = document.title;
          }

          document.title = awayTitle;
          if (icon) icon.href = "/failure.ico";

          if (timeoutId) clearTimeout(timeoutId);
        } else {
          document.title = backTitle;
          if (icon) icon.href = "/favicon.ico";

          timeoutId = window.setTimeout(() => {
            document.title = originalTitle;
          }, 1000);
        }
      });
    </script>

  </body>
</html>
