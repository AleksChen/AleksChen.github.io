---
import type { Locale } from "@/i18n/config";
import { localizePath } from "@/i18n/paths";
import { getUiText } from "@/i18n/ui";
import type { ShortPostData } from "@/lib/posts";
import Layout from "../layouts/Layout.astro";
import Mountain from "@/components/Mountain.astro";
import TerminalToggle from "@/components/TerminalToggle.astro";
import TerminalView from "@/components/TerminalView.astro";
import PostCard from "./PostCard.astro";

interface Props {
  posts: ShortPostData[];
  allPosts?: ShortPostData[];
  page: number;
  more: boolean;
  locale: Locale;
  languageSwitchPath?: string | null;
  seoAlternates?: Partial<Record<Locale, string>>;
}

const {
  posts,
  allPosts = posts,
  page,
  more,
  locale,
  languageSwitchPath,
  seoAlternates,
} = Astro.props;
const ui = getUiText(locale);
const nextLocale = locale === "zh" ? "en" : "zh";
const resolvedLanguageSwitchPath =
  languageSwitchPath === undefined
    ? localizePath(Astro.url.pathname, nextLocale)
    : languageSwitchPath;
---

<Layout
  locale={locale}
  languageSwitchPath={resolvedLanguageSwitchPath}
  title="AleksChen's Blog"
  description={ui.home.description}
  seo={{
    type: "website",
    locale,
    alternateLocales: seoAlternates,
    keywords:
      locale === "zh"
        ? [
            "全栈工程师",
            "Web 全栈",
            "AI Builder",
            "前端工程",
            "AI 编程",
            "跨端开发",
            "网络技术",
            "技术博客",
          ]
        : [
            "Full-stack Engineer",
            "Web Engineering",
            "AI Builder",
            "Frontend Engineering",
            "AI Coding",
            "Cross-platform Development",
            "Networking",
            "Tech Blog",
          ],
  }}
>
  <div slot="operations" class="flex items-center h-full">
    <TerminalToggle locale={locale} />
  </div>

  <div slot="background" class="hidden md:block view-card-bg">
    <Mountain />
  </div>

  <div class="flex flex-col relative z-10 items-center w-full">
    <div class="view-terminal w-full hidden">
      <TerminalView posts={allPosts} locale={locale} />
    </div>

    <div class="view-card retro-shell flex w-full flex-col gap-8">
      <section
        id="hero-section"
        class="grid gap-5 rounded-lg border-2 border-text bg-card p-5 shadow-[5px_5px_0_0_var(--color-accent)] md:grid-cols-[minmax(0,1fr)_auto] md:items-end md:p-7"
      >
        <div class="min-w-0">
          <div class="page-kicker mb-3">AleksChen</div>
          <h1
            class="min-h-[1.05em] text-3xl font-black leading-none tracking-tight text-text md:text-5xl"
          >
            {ui.home.intro}
          </h1>
          <p class="page-description mt-4">
            {ui.home.lead}
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            {ui.home.identity.map((label) => <span class="retro-chip">{label}</span>)}
          </div>
        </div>

        <nav
          class="grid grid-cols-1 gap-2 sm:grid-cols-3 md:min-w-[340px] md:grid-cols-1"
          aria-label={ui.nav.mainNavAria}
        >
          <a href={localizePath("/about", locale)} class="retro-link-button">
            <div class="i-ri:user-3-line"></div>
            {ui.home.ctaAbout}
          </a>
          <a href={localizePath("/about#skills", locale)} class="retro-link-button">
            <div class="i-ri:stack-line"></div>
            {ui.home.ctaSkills}
          </a>
          <a
            href={localizePath("/about#projects", locale)}
            class="retro-link-button"
          >
            <div class="i-ri:rocket-line"></div>
            {ui.home.ctaProjects}
          </a>
        </nav>
      </section>

      <div class="flex flex-col gap-2 border-b-2 border-text pb-4">
        <div class="page-kicker">{ui.home.latest}</div>
        <p class="text-sm font-bold text-text-muted">
          {ui.home.latestDescription}
        </p>
      </div>

      <div
        class="home-post-grid grid w-full grid-cols-1 gap-4 md:grid-cols-2 md:gap-x-5 md:gap-y-7 xl:grid-cols-3"
      >
        {
          posts.map((item, index) => (
            <PostCard
              item={item}
              index={index}
              locale={locale}
              noIntroText={ui.home.noIntro}
              formattedDate={new Date(item.createTime).toLocaleDateString(
                locale === "zh" ? "zh-CN" : "en-US"
              )}
            />
          ))
        }
      </div>

      {
        more && (
          <div class="w-full flex justify-center mt-8 mb-8">
            <a
              href={localizePath(`/${page + 1}`, locale)}
              class="retro-link-button px-8 py-3"
            >
              {ui.home.loadMore}
            </a>
          </div>
        )
      }
    </div>
  </div>
</Layout>

<script>
  const heroSection = document.getElementById("hero-section");
  if (heroSection) {
    const fadeOutHeight = 360;
    let ticking = false;

    const handleScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          if (scrollY <= fadeOutHeight) {
            const opacity = Math.max(0.72, 1 - scrollY / fadeOutHeight);
            heroSection.style.opacity = opacity.toString();
            heroSection.style.visibility = "visible";
          } else {
            heroSection.style.opacity = "0.72";
            heroSection.style.visibility = "visible";
          }
          ticking = false;
        });
        ticking = true;
      }
    };

    handleScroll();
    window.addEventListener("scroll", handleScroll, { passive: true });
  }

  const postGrid = document.querySelector(".home-post-grid");
  const postCards = Array.from(document.querySelectorAll(".home-post-card"));
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (
    postGrid &&
    postCards.length > 0 &&
    "IntersectionObserver" in window &&
    !prefersReducedMotion
  ) {
    const viewportHeight =
      window.innerHeight || document.documentElement.clientHeight;

    postCards.forEach((card) => {
      const rect = card.getBoundingClientRect();
      const inViewport =
        rect.bottom > viewportHeight * 0.12 && rect.top < viewportHeight * 0.88;
      if (inViewport) {
        card.classList.add("is-visible");
      }
    });

    postGrid.classList.add("cards-motion-ready");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting);
        });
      },
      {
        threshold: 0.14,
        rootMargin: "-8% 0px -14% 0px",
      },
    );

    postCards.forEach((card) => observer.observe(card));
  }
</script>

<style is:global>
  html.terminal-mode .view-card,
  html.terminal-mode .view-card-bg {
    display: none !important;
  }

  html.terminal-mode .view-terminal {
    display: block !important;
  }

  html.terminal-mode:has(.view-terminal) body {
    background-color: #121212 !important;
    background-image: none !important;
  }

  html.terminal-mode:has(.view-terminal) #main-header,
  html.terminal-mode:has(.view-terminal) footer {
    display: none !important;
  }

  html.terminal-mode:has(.view-terminal) main {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
    display: block;
  }

  .home-post-card {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    transition:
      opacity 420ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 300ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: opacity, transform;
  }

  .home-post-grid.cards-motion-ready .home-post-card {
    opacity: 0;
    transform: translate3d(0, 20px, 0) scale(0.98);
  }

  .home-post-grid.cards-motion-ready .home-post-card.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .home-post-grid.cards-motion-ready .home-post-card:not(.is-visible) {
    transition-delay: 0ms !important;
  }

  .home-post-grid.cards-motion-ready .home-post-card.is-visible:hover {
    transform: translate3d(-2px, -3px, 0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-post-card,
    .home-post-grid.cards-motion-ready .home-post-card,
    .home-post-grid.cards-motion-ready .home-post-card.is-visible,
    .home-post-card:hover,
    .home-post-grid.cards-motion-ready .home-post-card.is-visible:hover {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  import "@/shared/sound";
</script>
