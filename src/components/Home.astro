---
import Layout from "../layouts/Layout.astro";
import type { ShortPostData } from "@/lib/posts";
// import Rocket from "@/components/Rocket.astro";
import Mountain from "@/components/Mountain.astro";
import TypeWriter from "@/components/TypeWriter.astro";

import { PostCard } from "./PostCard";

interface Props {
  posts: ShortPostData[];
  page: number;
  more: boolean;
}

const { posts, page, more } = Astro.props;
---

<Layout
  title="前端与 AI 实践博客"
  description="聚焦前端工程、AI 编程、跨端开发与网络技术，持续输出可落地的实战笔记与源码解析。"
  seo={{
    type: "website",
    keywords: ["前端工程", "AI 编程", "跨端开发", "网络技术", "技术博客"],
  }}
>
  <div slot="background" class="hidden md:block">
    <!-- Three.js 火箭背景 -->
    <!-- <Rocket /> -->
    <!-- 山峰视差背景 -->
    <Mountain />
  </div>

  <div class="flex flex-col gap-8 relative z-10 items-center">
    <section id="hero-section" class="text-center py-8 md:py-12">
      <h1
        class="text-4xl md:text-7xl font-bold text-text mb-6 drop-shadow-[4px_4px_0_var(--color-shadow)] min-h-[1.2em]"
      >
        <TypeWriter
          text="AleksChen's Blog"
          speed={150}
          wait={3000}
          loop={false}
          cursor={false}
        />
      </h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto min-h-[1.5em]">
        <TypeWriter
          text="活在当下 记录时间"
          speed={250}
          wait={3000}
          loop={false}
          cursor={false}
        />
      </p>
    </section>

    <div
      class="home-post-grid grid grid-cols-1 gap-4 md:gap-x-5 md:gap-y-8 w-full max-w-[1120px] md:grid-cols-2 xl:grid-cols-3 px-1 md:px-0"
    >
      {
        posts.map((item, index) => (
          <PostCard
            item={item}
            index={index}
            formattedDate={new Date(item.createTime).toLocaleDateString()}
          />
        ))
      }
    </div>

    {
      more && (
        <div class="w-full flex justify-center mt-8">
          <a href={`/${page + 1}`} class="btn btn-primary px-8 py-3">
            加载更多
          </a>
        </div>
      )
    }
  </div>
</Layout>

<script>
  // Hero section 淡出效果
  const heroSection = document.getElementById("hero-section");
  if (heroSection) {
    const fadeOutHeight = 249; // 滚动多少像素后完全消失
    let ticking = false;

    const handleScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          if (scrollY <= fadeOutHeight) {
            const opacity = Math.max(0, 1 - scrollY / fadeOutHeight);
            heroSection.style.opacity = opacity.toString();
            heroSection.style.visibility = "visible";
          } else {
            heroSection.style.opacity = "0";
            heroSection.style.visibility = "hidden";
          }
          ticking = false;
        });
        ticking = true;
      }
    };

    handleScroll(); // 初始化
    window.addEventListener("scroll", handleScroll, { passive: true });
  }

  // 首页卡片滚动显隐效果：进入视口渐显，离开视口渐隐
  const postGrid = document.querySelector(".home-post-grid");
  const postCards = Array.from(document.querySelectorAll(".home-post-card"));
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (
    postGrid &&
    postCards.length > 0 &&
    "IntersectionObserver" in window &&
    !prefersReducedMotion
  ) {
    const viewportHeight =
      window.innerHeight || document.documentElement.clientHeight;

    // 先标记首屏卡片，避免初始闪烁
    postCards.forEach((card) => {
      const rect = card.getBoundingClientRect();
      const inViewport =
        rect.bottom > viewportHeight * 0.12 && rect.top < viewportHeight * 0.88;
      if (inViewport) {
        card.classList.add("is-visible");
      }
    });

    postGrid.classList.add("cards-motion-ready");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting);
        });
      },
      {
        threshold: 0.14,
        rootMargin: "-8% 0px -14% 0px",
      },
    );

    postCards.forEach((card) => observer.observe(card));
  }
</script>

<style is:global>
  .home-post-card {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    transition:
      opacity 420ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 300ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: opacity, transform;
  }

  .home-post-card:hover {
    transform: translate3d(-2px, -3px, 0) scale(1);
  }

  .home-post-grid.cards-motion-ready .home-post-card {
    opacity: 0;
    transform: translate3d(0, 20px, 0) scale(0.98);
  }

  .home-post-grid.cards-motion-ready .home-post-card.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .home-post-grid.cards-motion-ready .home-post-card:not(.is-visible) {
    transition-delay: 0ms !important;
  }

  .home-post-grid.cards-motion-ready .home-post-card.is-visible:hover {
    transform: translate3d(-2px, -3px, 0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-post-card,
    .home-post-grid.cards-motion-ready .home-post-card,
    .home-post-grid.cards-motion-ready .home-post-card.is-visible,
    .home-post-card:hover,
    .home-post-grid.cards-motion-ready .home-post-card.is-visible:hover {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
